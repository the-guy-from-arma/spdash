<Window x:Class="SeapowerMultiplayer.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seapower Multiplayer Launcher"
        Width="780" Height="840"
        MinWidth="680" MinHeight="720"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryBg}">

    <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Update Banner -->
                <RowDefinition Height="Auto"/>
                <!-- Game Path -->
                <RowDefinition Height="Auto"/>
                <!-- Separator -->
                <RowDefinition Height="Auto"/>
                <!-- Network Settings -->
                <RowDefinition Height="Auto"/>
                <!-- Public Registry -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
                <RowDefinition Height="Auto"/>
                <!-- Status -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,16">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button x:Name="BtnDiscord"
                        Click="BtnDiscord_Click"
                        ToolTip="Join our Discord"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="4,2"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center">
                        <Path Data="M19.27 5.33C17.94 4.71 16.5 4.26 15 4a.09.09 0 0 0-.07.03c-.18.33-.39.76-.53 1.09a16.09 16.09 0 0 0-4.8 0c-.14-.34-.36-.76-.54-1.09c-.01-.02-.04-.03-.07-.03c-1.5.26-2.93.71-4.27 1.33c-.01 0-.02.01-.03.02c-2.72 4.07-3.47 8.03-3.1 11.95c0 .02.01.04.03.05c1.8 1.32 3.53 2.12 5.24 2.65c.03.01.06 0 .07-.02c.4-.55.76-1.13 1.07-1.74c.02-.04 0-.08-.04-.09c-.57-.22-1.11-.48-1.64-.78c-.04-.02-.04-.08-.01-.11c.11-.08.22-.17.33-.25c.02-.02.05-.02.07-.01c3.44 1.57 7.15 1.57 10.55 0c.02-.01.05-.01.07.01c.11.09.22.17.33.26c.04.03.04.09-.01.11c-.52.31-1.07.56-1.64.78c-.04.01-.05.06-.04.09c.32.61.68 1.19 1.07 1.74c.03.01.06.02.09.01c1.72-.53 3.45-1.33 5.25-2.65c.02-.01.03-.03.03-.05c.44-4.53-.73-8.46-3.1-11.95c-.01-.01-.02-.02-.04-.02zM8.52 14.91c-1.03 0-1.89-.95-1.89-2.12s.84-2.12 1.89-2.12c1.06 0 1.9.96 1.89 2.12c0 1.17-.84 2.12-1.89 2.12zm6.97 0c-1.03 0-1.89-.95-1.89-2.12s.84-2.12 1.89-2.12c1.06 0 1.9.96 1.89 2.12c0 1.17-.83 2.12-1.89 2.12z"
                              Fill="#5865F2"
                              Width="20" Height="20"
                              Stretch="Uniform"/>
                    </Button>
                    <TextBlock x:Name="TxtVersion"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="12"/>
                    <TextBlock Text=" BETA"
                           Foreground="{StaticResource ErrorRed}"
                           FontSize="12"
                           FontWeight="Bold"/>
                </StackPanel>
                <TextBlock Text="Seapower Multiplayer"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="22"
                       FontWeight="Bold"/>
            </DockPanel>

            <!-- Update Banner (hidden by default) -->
            <Border x:Name="PnlUpdate" Grid.Row="1" Visibility="Collapsed"
                Background="#30FFA500" CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
                <DockPanel>
                    <Button x:Name="BtnUpdate" Content="Update Now"
                        DockPanel.Dock="Right" Padding="12,4"
                        Click="BtnUpdate_Click"/>
                    <TextBlock x:Name="TxtUpdateInfo"
                           Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
                </DockPanel>
            </Border>

            <!-- Game Path Section -->
            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <Label Content="Game Directory"/>
                <DockPanel>
                    <Button x:Name="BtnBrowse"
                        Content="Browse"
                        DockPanel.Dock="Right"
                        Margin="8,0,0,0"
                        Padding="12,6"
                        Click="BtnBrowse_Click"/>
                    <TextBox x:Name="TxtGamePath"
                         IsReadOnly="True"/>
                </DockPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Ellipse x:Name="StatusDot"
                         Width="10" Height="10"
                         Fill="{StaticResource WarningOrange}"
                         VerticalAlignment="Center"
                         Margin="0,0,6,0"/>
                    <TextBlock x:Name="TxtInstallStatus"
                           Text="Not Installed"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- Separator -->
            <Rectangle Grid.Row="3"
                   Height="1"
                   Fill="{StaticResource BorderColor}"
                   Margin="0,4,0,12"/>

            <!-- Network Settings -->
            <StackPanel Grid.Row="4">
                <Label Content="NETWORK SETTINGS"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,8"/>

                <!-- Connection Type -->
                <Label Content="Connection Type"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="RbSteam"
                             Content="Steam"
                             GroupName="Transport"
                             IsChecked="True"
                             Margin="0,0,20,0"
                             Checked="Transport_Changed"/>
                    <RadioButton x:Name="RbDirectIP"
                             Content="Direct IP"
                             GroupName="Transport"
                             Checked="Transport_Changed"/>
                </StackPanel>

                <!-- Direct IP Settings (hidden when Steam) -->
                <StackPanel x:Name="PnlDirectIP" Visibility="Collapsed">
                    <!-- Role -->
                    <Label Content="Role"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <RadioButton x:Name="RbHost"
                                 Content="Host"
                                 GroupName="Role"
                                 IsChecked="True"
                                 Margin="0,0,20,0"
                                 Checked="Role_Changed"/>
                        <RadioButton x:Name="RbClient"
                                 Content="Client"
                                 GroupName="Role"
                                 Checked="Role_Changed"/>
                    </StackPanel>

                <!-- Host IP -->
                <Label Content="Host IP"/>
                <TextBox x:Name="TxtHostIP"
                         Text="0.0.0.0"
                         TextChanged="TxtHostIP_TextChanged"
                         IsEnabled="False"
                         Margin="0,0,0,12"/>

                    <!-- Port -->
                    <Label Content="Port"/>
                    <TextBox x:Name="TxtPort"
                         Text="7777"
                         TextChanged="TxtPort_TextChanged"
                         Margin="0,0,0,12"/>

                    <!-- Auto-connect -->
                    <CheckBox x:Name="ChkAutoConnect"
                          Content="Auto-connect on launch"
                          Margin="0,0,0,4"/>
                </StackPanel>

                <!-- Game Settings -->
                <Rectangle Height="1"
                       Fill="{StaticResource BorderColor}"
                       Margin="0,8,0,12"/>

                <Label Content="GAME SETTINGS"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,8"/>

                <CheckBox x:Name="ChkTimeVote"
                      Content="Time compression voting (both players must agree)"
                      Margin="0,0,0,4"/>

                <CheckBox x:Name="ChkPvP"
                      Content="PvP mode (players control opposing sides)"
                      Margin="0,6,0,4"/>

                <!-- State sync rates (host only) -->
                <Label Content="State Sync Rates (Hz, 1-60, host only)" Margin="0,8,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Missiles:"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                    <TextBox x:Name="TxtMissileHz"
                         Text="20"
                         Width="50"
                         TextChanged="TxtHz_TextChanged"
                         Margin="0,0,20,0"/>
                    <TextBlock Text="Units:"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                    <TextBox x:Name="TxtUnitHz"
                         Text="10"
                         Width="50"
                         TextChanged="TxtHz_TextChanged"/>
                </StackPanel>
            </StackPanel>

            <!-- Public Registry -->
            <Border Grid.Row="5"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,14,0,0"
                    Background="{StaticResource SecondaryBg}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <Button x:Name="BtnRefreshServers"
                                Content="Refresh Servers"
                                DockPanel.Dock="Right"
                                Padding="12,6"
                                Click="BtnRefreshServers_Click"/>
                        <TextBlock Text="PUBLIC REGISTRY"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <Label Content="Registry API"/>
                    <TextBox x:Name="TxtRegistryUrl"
                             Text="https://spdash-production.up.railway.app"
                             Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Label Content="Public Servers"/>
                            <ListBox x:Name="LstServers"
                                     Height="128"
                                     DisplayMemberPath="DisplayName"
                                     Background="{StaticResource PrimaryBg}"
                                     Foreground="{StaticResource TextPrimary}"
                                     BorderBrush="{StaticResource BorderColor}"
                                     SelectionChanged="LstServers_SelectionChanged"/>
                            <TextBlock x:Name="TxtSelectedServer"
                                       Text="No server selected."
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"/>
                            <Button x:Name="BtnConnectSelected"
                                    Content="Connect Selected Server"
                                    Padding="12,8"
                                    Margin="0,8,0,0"
                                    IsEnabled="False"
                                    Click="BtnConnectSelected_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Label Content="Host Public Server"/>
                            <TextBox x:Name="TxtServerName"
                                     Text="Sea Power Fleet"
                                     Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtPublicIp"
                                         Grid.Column="0"
                                         ToolTip="Leave blank to let Railway infer the public IP"
                                         Text=""
                                         />
                                <TextBox x:Name="TxtRegion"
                                         Grid.Column="2"
                                         ToolTip="Optional region, e.g. US-East"
                                         Text=""/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtPlayerCount"
                                         Grid.Column="0"
                                         Text="1"
                                         ToolTip="Current player count"/>
                                <TextBox x:Name="TxtMaxPlayers"
                                         Grid.Column="2"
                                         Text="4"
                                         ToolTip="Max players"/>
                            </Grid>
                            <TextBox x:Name="TxtScenarioName"
                                     Text=""
                                     ToolTip="Scenario name"
                                     Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtScenarioHash"
                                     Text=""
                                     ToolTip="Scenario or save hash"
                                     Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtRequiredMods"
                                     Text=""
                                     ToolTip="One required mod per line, or Name|WorkshopId"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Height="70"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,8"/>
                            <Button x:Name="BtnHostPublic"
                                    Content="Host Public Server"
                                    Padding="12,8"
                                    Click="BtnHostPublic_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Buttons -->
            <DockPanel Grid.Row="6" Margin="0,12,0,0">
                <Button x:Name="BtnLaunch"
                    Content="Launch Game"
                    DockPanel.Dock="Right"
                    Padding="24,10"
                    IsEnabled="False"
                    Click="BtnLaunch_Click"/>
                <Button x:Name="BtnInstall"
                    Content="Install"
                    Padding="24,10"
                    Margin="0,0,12,0"
                    Click="BtnInstall_Click"/>
                <Button x:Name="BtnFeedback"
                    Content="Send Feedback"
                    Padding="24,10"
                    Margin="0,0,12,0"
                    Click="BtnFeedback_Click"/>
            </DockPanel>

            <!-- Status Bar -->
            <Border Grid.Row="7"
                Background="{StaticResource SecondaryBg}"
                CornerRadius="4"
                Padding="10,6"
                Margin="0,12,0,0">
                <TextBlock x:Name="TxtStatus"
                       Text="Ready"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="12"/>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
