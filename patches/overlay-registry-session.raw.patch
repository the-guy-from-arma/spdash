+        private void RefreshRegistrySession()
+        {
+            if (Time.unscaledTime < _registrySessionPollAt) return;
+            _registrySessionPollAt = Time.unscaledTime + 2f;
+
+            try
+            {
+                _registrySessionPath ??= Path.Combine(BepInEx.Paths.ConfigPath, RegistrySessionFileName);
+                if (!File.Exists(_registrySessionPath))
+                {
+                    _registrySession = null;
+                    _registrySessionWriteTimeUtc = DateTime.MinValue;
+                    return;
+                }
+
+                DateTime writeTime = File.GetLastWriteTimeUtc(_registrySessionPath);
+                if (_registrySession != null && writeTime == _registrySessionWriteTimeUtc) return;
+
+                string json = File.ReadAllText(_registrySessionPath);
+                _registrySession = RegistrySessionInfo.FromJson(json);
+                _registrySessionWriteTimeUtc = writeTime;
+            }
+            catch (Exception ex)
+            {
+                _registrySession = new RegistrySessionInfo
+                {
+                    ServerName = "Registry handoff unreadable",
+                    LauncherStatus = ex.GetType().Name,
+                    VerificationStatus = "warning"
+                };
+            }
+        }
+
+        private sealed class RegistrySessionInfo
+        {
+            public string RegistryUrl = "";
+            public string ServerId = "";
+            public string ServerName = "";
+            public string LauncherStatus = "";
+            public string VerificationStatus = "";
+            public string Visibility = "";
+            public string Mode = "";
+            public string Transport = "";
+            public string PublicIp = "";
+            public int Port;
+            public string PluginVersion = "";
+            public string GameVersion = "";
+            public string ScenarioName = "";
+            public string ScenarioHash = "";
+            public bool IsPublicListed;
+            public readonly List<RegistryModInfo> RequiredMods = new();
+            public readonly List<string> MissingMods = new();
+
+            public bool HasMissingMods => MissingMods.Count > 0;
+
+            public static RegistrySessionInfo FromJson(string json)
+            {
+                var info = new RegistrySessionInfo
+                {
+                    RegistryUrl = JsonString(json, "registryUrl"),
+                    ServerId = JsonString(json, "serverId"),
+                    ServerName = JsonString(json, "serverName"),
+                    LauncherStatus = JsonString(json, "launcherStatus"),
+                    VerificationStatus = JsonString(json, "verificationStatus"),
+                    Visibility = JsonString(json, "visibility"),
+                    Mode = JsonString(json, "mode"),
+                    Transport = JsonString(json, "transport"),
+                    PublicIp = JsonString(json, "publicIp"),
+                    Port = JsonInt(json, "port"),
+                    PluginVersion = JsonString(json, "pluginVersion"),
+                    GameVersion = JsonString(json, "gameVersion"),
+                    ScenarioName = JsonString(json, "scenarioName"),
+                    ScenarioHash = JsonString(json, "scenarioHash"),
+                    IsPublicListed = JsonBool(json, "isPublicListed")
+                };
+
+                foreach (Match match in Regex.Matches(json, "\"requiredMods\"\\s*:\\s*\\[(.*?)\\]", RegexOptions.Singleline))
+                {
+                    foreach (Match item in Regex.Matches(match.Groups[1].Value, "\\{(.*?)\\}", RegexOptions.Singleline))
+                    {
+                        var body = item.Groups[1].Value;
+                        string name = JsonString(body, "name");
+                        string workshopId = JsonString(body, "workshopId");
+                        if (string.IsNullOrEmpty(name) && string.IsNullOrEmpty(workshopId)) continue;
+                        info.RequiredMods.Add(new RegistryModInfo
+                        {
+                            Name = string.IsNullOrEmpty(name) ? $"Workshop {workshopId}" : name,
+                            WorkshopId = workshopId,
+                            Required = !Regex.IsMatch(body, "\"required\"\\s*:\\s*false", RegexOptions.IgnoreCase)
+                        });
+                    }
+                }
+
+                Match missing = Regex.Match(json, "\"missingMods\"\\s*:\\s*\\[(.*?)\\]", RegexOptions.Singleline);
+                if (missing.Success)
+                {
+                    foreach (Match item in Regex.Matches(missing.Groups[1].Value, "\"((?:\\\\.|[^\"])*)\""))
+                        info.MissingMods.Add(Regex.Unescape(item.Groups[1].Value));
+                }
+
+                return info;
+            }
+        }
+
+        private sealed class RegistryModInfo
+        {
+            public string Name = "";
+            public string WorkshopId = "";
+            public bool Required = true;
+        }
+
+        private static string JsonString(string json, string name)
+        {
+            Match match = Regex.Match(json, $"\"{Regex.Escape(name)}\"\\s*:\\s*\"((?:\\\\.|[^\"])*)\"");
+            return match.Success ? Regex.Unescape(match.Groups[1].Value) : "";
+        }
+
+        private static int JsonInt(string json, string name)
+        {
+            Match match = Regex.Match(json, $"\"{Regex.Escape(name)}\"\\s*:\\s*(\\d+)");
+            return match.Success && int.TryParse(match.Groups[1].Value, out int value) ? value : 0;
+        }
+
+        private static bool JsonBool(string json, string name)
+        {
+            Match match = Regex.Match(json, $"\"{Regex.Escape(name)}\"\\s*:\\s*(true|false)", RegexOptions.IgnoreCase);
+            return match.Success && match.Groups[1].Value.Equals("true", StringComparison.OrdinalIgnoreCase);
+        }
+
+        private static string ShortText(string value, int max)
+        {
+            if (string.IsNullOrEmpty(value) || value.Length <= max) return value;
+            return value.Substring(0, Math.Max(0, max - 1)) + "...";
+        }
