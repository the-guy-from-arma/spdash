+        private void DrawRegistrySession()
+        {
+            var session = _registrySession;
+            if (session == null) return;
+
+            DrawSectionTitle("O", "REGISTRY");
+
+            GUIStyle statusStyle = session.HasMissingMods ? _warningStyle! :
+                session.VerificationStatus == "verified" || session.LauncherStatus == "Ready" ? _successStyle! :
+                session.VerificationStatus == "blocked" ? _criticalStyle! : _dimLabelStyle!;
+
+            string serverName = string.IsNullOrEmpty(session.ServerName) ? "No server name" : session.ServerName;
+            GUILayout.Label($"Server: {ShortText(serverName, 34)}", _labelStyle);
+
+            if (!string.IsNullOrEmpty(session.LauncherStatus) || !string.IsNullOrEmpty(session.VerificationStatus))
+            {
+                string status = !string.IsNullOrEmpty(session.LauncherStatus)
+                    ? session.LauncherStatus
+                    : session.VerificationStatus;
+                GUILayout.Label($"Status: {status}", statusStyle);
+            }
+
+            if (!string.IsNullOrEmpty(session.ScenarioName))
+                GUILayout.Label($"Scenario: {ShortText(session.ScenarioName, 32)}", _labelStyle);
+            if (!string.IsNullOrEmpty(session.ScenarioHash))
+                GUILayout.Label($"Scenario hash: {ShortText(session.ScenarioHash, 18)}", _dimLabelStyle);
+
+            string endpoint = session.Port > 0 && !string.IsNullOrEmpty(session.PublicIp)
+                ? $"{session.PublicIp}:{session.Port}"
+                : "";
+            if (!string.IsNullOrEmpty(endpoint))
+                GUILayout.Label($"Endpoint: {endpoint}", _dimLabelStyle);
+
+            GUILayout.Label($"Mode: {session.Mode}  Transport: {session.Transport}", _dimLabelStyle);
+            if (!string.IsNullOrEmpty(session.PluginVersion) || !string.IsNullOrEmpty(session.GameVersion))
+                GUILayout.Label($"Plugin {session.PluginVersion}  Game {session.GameVersion}", _dimLabelStyle);
+
+            if (session.HasMissingMods)
+            {
+                GUILayout.Label($"Missing mods: {session.MissingMods.Count}", _warningStyle);
+                for (int i = 0; i < Mathf.Min(3, session.MissingMods.Count); i++)
+                    GUILayout.Label($"  - {ShortText(session.MissingMods[i], 30)}", _warningStyle);
+            }
+
+            _foldRegistryMods = DrawSectionHeader($"Required Mods ({session.RequiredMods.Count})", _foldRegistryMods,
+                session.HasMissingMods ? SyncStatus.Degraded : SyncStatus.OK);
+            if (_foldRegistryMods)
+            {
+                if (session.RequiredMods.Count == 0)
+                {
+                    GUILayout.Label("  None reported", _dimLabelStyle);
+                }
+                else
+                {
+                    int count = Mathf.Min(6, session.RequiredMods.Count);
+                    for (int i = 0; i < count; i++)
+                    {
+                        var mod = session.RequiredMods[i];
+                        string workshop = string.IsNullOrEmpty(mod.WorkshopId) ? "" : $" ({mod.WorkshopId})";
+                        GUILayout.Label($"  - {ShortText(mod.Name + workshop, 32)}", _dimLabelStyle);
+                    }
+                    if (session.RequiredMods.Count > count)
+                        GUILayout.Label($"  +{session.RequiredMods.Count - count} more", _dimLabelStyle);
+                }
+            }
+        }
