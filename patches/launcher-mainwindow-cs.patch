+            _heartbeatCts = null;
+
+            if (string.IsNullOrWhiteSpace(_activeHostServerId))
+                return;
+
+            try
+            {
+                await _registry.StopServerAsync(_config.Settings, _activeHostServerId);
+            }
+            catch
+            {
+                // The registry expires listings by TTL even if stop fails.
+            }
+            finally
+            {
+                _activeHostServerId = null;
+            }
+        }
